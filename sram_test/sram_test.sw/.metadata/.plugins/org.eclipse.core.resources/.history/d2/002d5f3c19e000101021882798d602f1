void print_injection_result(int i)
{
	switch (converted_data & mask_inj_p)
	{
	case 0x29:
		xil_printf("SRAM %d one bit error injection completed !\r\n", i);
		break;
	case 0x49:
		xil_printf("SRAM %d two bits error injection completed !\r\n", i);
		break;
	case 0x69:
		xil_printf("SRAM %d three bits error injection completed !\r\n", i);
		break;
	default:
		xil_printf("SRAM %d Injection error failed !\r\n", i);
		break;
	}
}

void print_1(int intel)
{
	if (err_counter_0)
	{
		xil_printf("SRAM %d testing completed !\r\n", intel);
		xil_printf("SRAM %d Test result:\r\n", intel);

		if (!((converted_data == rd_counter_1_ce0) || (converted_data == rd_counter_2_ce0) || (converted_data == rd_counter_3_ce0) || (converted_data == rd_counter_addr_ce0) || (converted_data == rd_counter_1_ce1) || (converted_data == rd_counter_2_ce1) || (converted_data == rd_counter_3_ce1) || (converted_data == rd_counter_addr_ce1)))
		{
			if (!rd_flag_0)
			{
				xil_printf("SRAM %d Test Round %d Error Count: %u\r\n", intel, finsh_flag_0 + 1, err_cnt_0[finsh_flag_0]);
				if (auto_flag)
				{
					xil_printf("SRAM %d Test Round %d Read counter 3: %u\r\n", intel, finsh_flag_0 + 1, err_inj_0[finsh_flag_0]);
				}
				if (err_sys_flag_0)
				{
					xil_printf("SRAM %d Test Round %d Three-Bit Error Injection Alarms Count: %u\r\n", intel, finsh_flag_0 + 1, err_sys_0[finsh_flag_0]);
					err_sys_flag_0 = 0;
				}
				if (count_0 > 0)
				{
					xil_printf("  During the full-address write-after-read test, data inconsistencies were detected in some memory locations !\r\n");
					xil_printf("  The following are the error data and their corresponding addresses:\r\n");
					for (int i = 1; i < count_0 + 1; i = i + 1)
					{
						printf("  Test Error %d : \r\n", i);
						printf("  SRAM %d Error Addr: 0x%08lx\r\n", intel, err_addr_0[finsh_flag_0][i]);
						printf("  SRAM %d Error Theoretical Data: 0x%016llx\r\n", intel, Theor_data_0[finsh_flag_0][i]);
						printf("  SRAM %d Error Actual Data: 0x%016llx\r\n", intel, Actual_data_0[finsh_flag_0][i]);
						printf("-----------------------------------------------------------------------------------------------\r\n");
					}
					print_failed();
				}
				else
				{
					print_passed();
				}

				err_counter_0 = 0;
			}
			else
			{
				xil_printf("SRAM %d Test Error Count: %u\r\n", intel, err_cnt_0[finsh_flag_0]);
				for (int i = 1; i < count_0 + 1; i = i + 1)
				{
					printf("  Test Error %d : \r\n", i);
					printf("  SRAM %d Error Addr: 0x%08lx\r\n", intel,  err_addr_0[finsh_flag_0][i]);
					printf("  SRAM %d Error Theoretical Data: 0x%016llx\r\n", intel, Theor_data_0[finsh_flag_0][i]);
					printf("  SRAM %d Error Actual Data: 0x%016llx\r\n", intel, Actual_data_0[finsh_flag_0][i]);
					printf("-----------------------------------------------------------------------------------------------\r\n");
				}
				if (err_sys_flag_0)
				{
					xil_printf("SRAM %d Test Round %d Three-Bit Error Injection Alarms Count: %u\r\n", intel, finsh_flag_0 + 1, err_sys_0[finsh_flag_0]);
					err_sys_flag_0 = 0;
				}
				rd_flag_0 = 0;
			}
		}
		else
		{
			switch (converted_data)
			{
			case rd_counter_1_ce0:
				xil_printf("SRAM %d Read Counter 1 : %u\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_1_ce1:
				xil_printf("SRAM %d Read Counter 1 : %u\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_2_ce0:
				xil_printf("SRAM %d Read Counter 2 : %u\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_2_ce1:
				xil_printf("SRAM %d Read Counter 2 : %u\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_3_ce0:
				xil_printf("SRAM %d Read Counter 3 : %u\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_3_ce1:
				xil_printf("SRAM %d Read Counter 3 : %u\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_addr_ce0:
				xil_printf("SRAM %d Read Counter 3 address : 0x%08x\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			case rd_counter_addr_ce1:
				xil_printf("SRAM %d Read Counter 3 address : 0x%08x\r\n", intel, err_inj_0[finsh_flag_0]);
				break;
			default:
				break;
			}
			err_counter_0 = 0;
		}
	}
	else
	{
		if (err_inj_flag_0)
		{
			print_injection_result(intel);
			err_inj_flag_0 = 0;
		}
		else
		{
			xil_printf("SRAM %d Test write completed !\r\n", intel);
		}
	}

	xil_printf("\r\n");
}
