void init_intr_sys()
{
	XGpioPs_init();

	Timer_init(&Timer, TIMER_LOAD_VALUE, TIMER_DEVICE_ID);

	Init_Intr_System(&Intc);

	Setup_Intr_Exception(&Intc);

	Timer_Setup_Intr_System(&Intc, &Timer, TIMER_IRPT_INTR);

	uart_init();

	initIicPs(&IicPs_0, IicPsCfgPtr_0, IIC_DEVICE_ID_1);

	init_flag();

	xQueue = xQueueCreate(1, sizeof(uint8_t));

	configASSERT(xQueue);

	xSemaphore = xSemaphoreCreateBinary();

	xEventGroup = xEventGroupCreate();

	xSemaphore_0 = xSemaphoreCreateBinary();

	xSemaphore_1 = xSemaphoreCreateBinary();

	xSemaphoreGive(xSemaphore);

	xSemaphoreGive(xSemaphore_0);

	xSemaphoreGive(xSemaphore_1);

	Timer_start(&Timer);

	Print_MOD_id();

	Print_BRD_id();

	IIC_config();

	lit_led();
}

