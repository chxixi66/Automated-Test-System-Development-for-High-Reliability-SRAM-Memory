void check_mode()
{

	switch (state[auto_round * Mode + flag])
	{

	case STATE_RAW:
		if (err_cnt_0[finsh_flag_0] != 0x0)
		{
			mode_cnt_0[auto_round * Mode + flag] = false;
		}
		else
		{
			mode_cnt_0[auto_round * Mode + flag] = true;
		}

		if (err_cnt_1[finsh_flag_1] != 0x0)
		{
			mode_cnt_1[auto_round * Mode + flag] = false;
		}
		else
		{
			mode_cnt_1[auto_round * Mode + flag] = true;
		}

		break;
	case STATE_INJ_0:
		if (((err_inj_0[finsh_flag_0] != err_data) || (err_cnt_0[finsh_flag_0] != 0x0)))
		{
			mode_cnt_0[auto_round * Mode + flag] = false;
		}
		else
		{
			mode_cnt_0[auto_round * Mode + flag] = true;
		}
		if (((err_inj_1[finsh_flag_1] != err_data) || (err_cnt_1[finsh_flag_1] != 0x0)))
		{
			mode_cnt_1[auto_round * Mode + flag] = false;
		}
		else
		{

			mode_cnt_1[auto_round * Mode + flag] = true;
		}

		break;
	case STATE_INJ_1:

		if (((err_inj_0[finsh_flag_0] != err_data) || (err_cnt_0[finsh_flag_0] != err_data) || (err_inj_addr_0[finsh_flag_0] != (u32)(err_data - (u32)0x01))))
		{

			mode_cnt_0[auto_round * Mode + flag] = false;
		}
		else
		{
			mode_cnt_0[auto_round * Mode + flag] = true;
		}

		if (((err_inj_1[finsh_flag_1] != err_data) || (err_cnt_1[finsh_flag_1] != err_data) || (err_inj_addr_1[finsh_flag_1] != (u32)(err_data - (u32)0x01))))
		{

			mode_cnt_1[auto_round * Mode + flag] = false;
		}
		else
		{

			mode_cnt_1[auto_round * Mode + flag] = true;
		}

		break;
	case STATE_INJ_2:

		if (((err_inj_0[finsh_flag_0] != err_data) || (err_cnt_0[finsh_flag_0] != err_data) || (err_inj_addr_0[finsh_flag_0] != (u32)(err_data + (u32)0x0007ffff))))
		{

			mode_cnt_0[auto_round * Mode + flag] = false;
		}
		else
		{
			mode_cnt_0[auto_round * Mode + flag] = true;
		}

		if (((err_inj_1[finsh_flag_1] != err_data) || (err_cnt_1[finsh_flag_1] != err_data) || (err_inj_addr_1[finsh_flag_1] != (u32)(err_data + (u32)0x0007ffff))))
		{

			mode_cnt_1[auto_round * Mode + flag] = false;
		}
		else
		{

			mode_cnt_1[auto_round * Mode + flag] = true;
		}

		break;
	case STATE_MARCHC_0:
	case STATE_MARCHC_1:

		bool any_error_0 = false;
		bool any_error_1 = false;

		for (int ch = 0; ch < 5; ch++)
