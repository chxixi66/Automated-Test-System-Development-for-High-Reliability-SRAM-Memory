void XGpioPs_init()
{

	ConfigPtr = XGpioPs_LookupConfig(GPIO_DEVICE_ID);
	XGpioPs_CfgInitialize(&Gpio, ConfigPtr, ConfigPtr->BaseAddr);
}

void Print_MOD_id()
{
	XGpioPs_SetDirectionPin(&Gpio, Gpio_10, 0x0);	 // input
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_10, 0x0); // input

	u32 MOD_ID;
	MOD_ID = XGpioPs_ReadPin(&Gpio, Gpio_10);
	if (MOD_ID == 0x0)
	{
		xil_printf("ZYNQ_MOD_A\n\r");
		mod = 1;
	}
	else
	{
		xil_printf("ZYNQ_MOD_B\n\r");
		mod = 0;
	}
}

void Print_BRD_id()
{

	XGpioPs_SetDirectionPin(&Gpio, Gpio_40, 0x0);	 // input
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_40, 0x0); // input
	XGpioPs_SetDirectionPin(&Gpio, Gpio_43, 0x0);	 // input
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_43, 0x0); // input
	XGpioPs_SetDirectionPin(&Gpio, Gpio_42, 0x0);	 // input
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_42, 0x0); // input
	XGpioPs_SetDirectionPin(&Gpio, Gpio_41, 0x0);	 // input
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_41, 0x0); // input

	u32 BRD_ID[4];
	BRD_ID[0] = XGpioPs_ReadPin(&Gpio, Gpio_40);
	BRD_ID[1] = XGpioPs_ReadPin(&Gpio, Gpio_43);
	BRD_ID[2] = XGpioPs_ReadPin(&Gpio, Gpio_42);
	BRD_ID[3] = XGpioPs_ReadPin(&Gpio, Gpio_41);

	for (int i = 0; i < 4; i++)
	{
		if (BRD_ID[i] == 0x1)
		{
			xil_printf("BRD %d status is enabled.\n\r", i + 1);
		}
		else
		{

			xil_printf("BRD %d status is disabled.\n\r", i + 1);
		}
	}
}

void lit_led()
{
	XGpioPs_SetDirectionPin(&Gpio, Gpio_0, 0x1);	// output
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_0, 0x1); // output
	XGpioPs_WritePin(&Gpio, Gpio_0, 0x0);			// light up the led
}

