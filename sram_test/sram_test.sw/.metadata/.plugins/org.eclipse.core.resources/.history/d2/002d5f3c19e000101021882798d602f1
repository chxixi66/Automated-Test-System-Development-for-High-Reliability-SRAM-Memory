void print_result()
{

	// EventBits_t xBits;
	// const EventBits_t xBitsToWaitFor = BIT_0 | BIT_1 ;

	// xBits = xEventGroupWaitBits(xEventGroup,xBitsToWaitFor,pdTRUE,pdTRUE, portMAX_DELAY);
	if (print_flag_0 && print_flag_1)
	{

		xil_printf("I1_");
		uart_double(lane_0.I_sense[finsh_flag_0]);
		xil_printf("\r\n");

		xil_printf("I2_");
		uart_double(lane_1.I_sense[finsh_flag_1]);
		xil_printf("\r\n");

		xil_printf("V1_");
		uart_double(lane_0.V_bus[finsh_flag_0]);
		xil_printf("\r\n");

		xil_printf("V2_");
		uart_double(lane_1.V_bus[finsh_flag_1]);
		xil_printf("\r\n");

		xil_printf("P1_");
		uart_double(lane_0.power[finsh_flag_0]);
		xil_printf("\r\n");

		xil_printf("P2_");
		uart_double(lane_1.power[finsh_flag_1]);
		xil_printf("\r\n");

		xil_printf("T1_");
		uart_double(lane_0.TMP[finsh_flag_0]);
		xil_printf("\r\n");

		xil_printf("T2_");
		uart_double(lane_1.TMP[finsh_flag_1]);
		xil_printf("\r\n");

		if (mod)
		{
			if (!executed_auto)
			{
				switch (state[auto_round * Mode + flag])
				{
				case STATE_MARCHC_0:
				case STATE_MARCHC_1:
					print_marchc_1(1);
					print_marchc_2(2);
					break;
				default:
					if (auto_flag && ((converted_data & mask_inj) == 0x00000009))
					{
						print_auto_Injection_1(1);
						print_auto_Injection_2(2);
					}
					else
					{
						print_1(1);
						print_2(2);
					}
					break;
				}
			}
			else
			{

				check_mode();
			}
		}
		else
		{

			if (!executed_auto)
			{
				switch (state[auto_round * Mode + flag])
				{
				case STATE_MARCHC_0:
				case STATE_MARCHC_1:
					print_marchc_1(3);
					print_marchc_2(4);
					break;
				default:
					if (auto_flag && ((converted_data & mask_inj) == 0x00000009))
					{
						print_auto_Injection_1(3);
						print_auto_Injection_2(4);
					}
					else
					{
						print_1(3);
						print_2(4);
					}
					break;
				}
			}
			else
			{

				check_mode();
			}
		}

		if (!executed_auto)
								{
												if (test_round == 10)
												{
													for (int i = (finsh_flag_0) * 10 + 1 ; i < (finsh_flag_0 + 1) * 10 + 1; i++)
													{
														xil_printf("sram_");
														xil_printf("%d\r\n", i);
														vTaskDelay(pdMS_TO_TICKS(1));
													}
												}
												else
												{
													for (int i = finsh_flag_0 + 1; i < (finsh_flag_0 + 1) * 100 + 1; i++)
													{
														xil_printf("sram_");
														xil_printf("%d\r\n", i);
														vTaskDelay(pdMS_TO_TICKS(1));
													}
												}
											}
	   else
		{

					float f = (float)(auto_round * Mode + flag) / (round_cnt * Mode) * 100;
					int s = (int)f;
					xil_printf("sram_");
					xil_printf("%d\r\n", s);
		}

		if ((finsh_flag_0 == test_round - 1) && (finsh_flag_1 == test_round - 1))
		{

			finsh_flag_0 = 0;
			finsh_flag_1 = 0;

			if (!executed_auto)
			{

				print_tail();
			}
			else
			{
				xil_printf("-----------------------------------------------------------------------------------------------\r\n");
				flag++;
			}

			if (flag == Mode)
			{

				taskENTER_CRITICAL();
				flag = 0;

				if(config_select == 0x0)
				{
				auto_round++;
				}
				taskEXIT_CRITICAL();

				free(voltage_info);

				config_data = (config_data + V_adder) % 9;
			}

			if (auto_round == round_cnt)
			{

				print_all();

				print_test_report();

				auto_round = 0;

				executed_auto = false;
			}

			xSemaphoreGive(xSemaphore);
		}
		else
		{

			finsh_flag_0++;
			finsh_flag_1++;
		}


		timeoutflag = 0;

		taskENTER_CRITICAL();
		print_flag_0 = 0;
		print_flag_1 = 0;
		taskEXIT_CRITICAL();
		xSemaphoreGive(xSemaphore_0);
		xSemaphoreGive(xSemaphore_1);
	}
}

void UART_Receive()
{

	u8 Auto_send_Buffer[1];
	u8 auto_rececount;
	auto_rececount = XUartPs_Recv(&UartPs, Auto_send_Buffer, 1);

	if (auto_rececount > 0)
	{
		xQueueSend(xQueue, &Auto_send_Buffer[0], 0UL);
	}
	
}


void p3v3_en()
{
	XGpioPs_SetDirectionPin(&Gpio, Gpio_28, 0x1);	 // output
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_28, 0x1); // output
	XGpioPs_WritePin(&Gpio, Gpio_28, 0x1);			 // 3v3 en
}

void p1v1_en()
{
	XGpioPs_SetDirectionPin(&Gpio, Gpio_37, 0x1);	 // output
	XGpioPs_SetOutputEnablePin(&Gpio, Gpio_37, 0x1); // output
	XGpioPs_WritePin(&Gpio, Gpio_37, 0x1);			 // 1v1 en
}

