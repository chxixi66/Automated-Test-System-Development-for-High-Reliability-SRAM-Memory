void convert_str_to_24bit(const u8 *rece_value, u32 *config, u32 *err_num)
{
	u32 CONFIG = 0;
	u32 ERR = 0;

	for (int i = 0; i < 4; i++)
	{
		CONFIG = (CONFIG << 1) | (rece_value[i] - '0');
	}
	*config = CONFIG;

	for (int i = 4; i < 24; i++)
	{
		ERR = (ERR << 1) | (rece_value[i] - '0');
	}
	*err_num = ERR;
}

void convert_str_to_2bit(const u8 *rece_value, u32 *config)
{
	u32 CONFIG = 0;

	for (int i = 0; i < 2; i++)
	{
		CONFIG = (CONFIG << 1) | (rece_value[i] - '0');
	}
	*config = CONFIG;

}

