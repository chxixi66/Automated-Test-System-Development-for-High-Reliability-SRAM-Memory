void convert_str_to_32bit(const u8 *rece_value, u32 *output, u32 *config, u32 *freq, u32 *Round, u32 *err_num, u32 *auto_counter)
{
	u32 decimal = 0;
	u32 CONFIG = 0;
	u32 Freq = 0;
	u32 ROUND = 0;
	u32 ERR = 0;
	u32 AUTO = 0;

	for (int i = 0; i < 15; i++)
	{
		decimal = (decimal << 1) | (rece_value[i] - '0');
	}
	*output = decimal;

	for (int i = 15; i < 19; i++)
	{
		CONFIG = (CONFIG << 1) | (rece_value[i] - '0');
	}
	*config = CONFIG;

	// for(int i = 19; i < 20 ; i++){
	Freq = (Freq << 1) | (rece_value[19] - '0');
	//}
	*freq = Freq;

	ROUND = (ROUND << 1) | (rece_value[20] - '0');
	*Round = ROUND;

	for (int i = 21; i < 41; i++)
	{
		ERR = (ERR << 1) | (rece_value[i] - '0');
	}
	*err_num = ERR;

	AUTO = (AUTO << 1) | (rece_value[41] - '0');
	*auto_counter = AUTO;
}

