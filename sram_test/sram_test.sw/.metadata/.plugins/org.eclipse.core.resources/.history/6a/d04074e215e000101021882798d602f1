void Marchc_collect(Marchc_info *m, u32 rcv_data, int lane, int ch, uint8_t round)
{

	uint32_t cnt = (u32)((rcv_data & 0x007ffff8) >> 3);

	Marchc_err_info *info = NULL;

	switch (ch)
	{
	case 0:
		m->Mar_err_cnt_0[round] = cnt;
		break;
	case 1:
		m->Mar_err_cnt_1[round] = cnt;
		break;
	case 2:
		m->Mar_err_cnt_2[round] = cnt;
		break;
	case 3:
		m->Mar_err_cnt_3[round] = cnt;
		break;
	case 4:
		m->Mar_err_cnt_4[round] = cnt;
		break;
	default:
		break;
	}

	switch (ch)
	{
	case 0:
		info = &err_info_0[round];
		break;
	case 1:
		info = &err_info_1[round];
		break;
	case 2:
		info = &err_info_2[round];
		break;
	case 3:
		info = &err_info_3[round];
		break;
	case 4:
		info = &err_info_4[round];
		break;
	default:
		break;
	}

	switch (lane)
	{
	case 0:
		Mar_count_0[ch] = (cnt >= (fifo_depth - 1)) ? (fifo_depth - 1) : cnt;
		break;
	case 1:
		Mar_count_1[ch] = (cnt >= (fifo_depth - 1)) ? (fifo_depth - 1) : cnt;
		break;
	default:
		break;
	}

	if (cnt > 0)
	{
		for (int i = 0; i < ((cnt >= (fifo_depth - 1)) ? (fifo_depth - 1) : cnt) + 1; i = i + 1)
		{

			switch (lane)
			{
			case 0:
			{
				info->err_addr_0[i] = Xil_In32((u32)err_addr_reg_0);
				u32 da = Xil_In32((u32)data_a_reg_0);
				u32 db = Xil_In32((u32)data_b_reg_0);
				u32 dc = Xil_In32((u32)data_c_reg_0);

				u32 c_low = dc & 0xff;
