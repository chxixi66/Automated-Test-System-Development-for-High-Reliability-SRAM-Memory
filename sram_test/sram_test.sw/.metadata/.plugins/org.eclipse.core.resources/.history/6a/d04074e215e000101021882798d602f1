		xil_printf("\r\n----------------------------------------------------------------------------------------------\r\n");
		xil_printf("                                       Single Mode Test Launched !                                \r\n");
		xil_printf("--------------------------------------------------------------------------------------------------\r\n");
	}
	else
	{
		xil_printf("\r\n-----------------------------------------------------------------------------------------------\r\n");
		xil_printf("                                       Start Full Modes Testing !                                  \r\n");
		xil_printf("----------------------------------------------------------------------------------------------\r\n");
	}
}

void copy_to_mode(RAW_info *raw, int dest_mode, uint8_t finish_flag, u32 ERR_ADDR[TEST_ROUND][fifo_depth], u64 ERR_THERO[TEST_ROUND][fifo_depth], u64 ERR_ACTUAL[TEST_ROUND][fifo_depth])
{
	memcpy(raw->err_addr[dest_mode],
		   ERR_ADDR[finish_flag],
		   fifo_depth * sizeof(u32));
	memcpy(raw->err_actual[dest_mode],
		   ERR_ACTUAL[finish_flag],
		   fifo_depth * sizeof(u64));
	memcpy(raw->err_theor[dest_mode],
		   ERR_THERO[finish_flag],
		   fifo_depth * sizeof(u64));
}

